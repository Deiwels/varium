VURIUM_API_BASE_URL=https://your-api-host.example.com
VURIUM_ADMIN_TOKEN=replace-with-superadmin-token

# Optional local writeback settings if your self-hosted n8n can write into the Obsidian repo.
VURIUM_OBSIDIAN_ROOT=/absolute/path/to/varium/docs

# Optional notification settings for the last-mile nodes you add in n8n.
VURIUM_OWNER_EMAIL=owner@example.com
VURIUM_SUPPORT_MAILBOX=support@vurium.com
