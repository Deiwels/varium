# VuriumBook Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080

# VuriumBook Backend (set in backend/.env)
# JWT_SECRET=your-secret-key
# GOOGLE_CLOUD_PROJECT=your-project-id
# SQUARE_TOKEN=your-square-token
# SQUARE_APP_ID=your-square-app-id
# SQUARE_APP_SECRET=your-square-app-secret
# SQUARE_LOCATION_ID=your-location
# SQUARE_DEVICE_ID=your-device
# SQUARE_ENV=sandbox
# TWILIO_ACCOUNT_SID=your-sid
# TWILIO_AUTH_TOKEN=your-token
# TWILIO_FROM=+1234567890
# APNS_KEY_ID=your-key
# APNS_TEAM_ID=your-team
# APNS_KEY_P8=base64-encoded-key
# APNS_BUNDLE_ID=com.your.app
# APNS_ENVIRONMENT=development
