# Local n8n environment template for the imported VuriumBook workflows.
# Do not commit real secrets.

N8N_BLOCK_ENV_ACCESS_IN_NODE=false

# Point n8n at the local backend while developing
VURIUM_API_BASE_URL=http://127.0.0.1:8080

# Superadmin bearer token used by workflow HTTP nodes
VURIUM_ADMIN_TOKEN=replace-with-local-superadmin-token

# Local writeback and notification settings
VURIUM_OBSIDIAN_ROOT=/Users/nazarii/Downloads/varium/docs
VURIUM_OWNER_EMAIL=nazarii@vurium.local
VURIUM_SUPPORT_MAILBOX=support@vurium.com
