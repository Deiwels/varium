# Local backend environment template for VuriumBook.
# Do not commit real secrets.
# This backend currently reads env vars from the process environment,
# so use this file as your local source template when launching the server.

# Core local runtime
NODE_ENV=development
PORT=8080
BACKEND_PUBLIC_URL=http://127.0.0.1:8080
VURIUM_OBSIDIAN_ROOT=/Users/nazarii/Downloads/varium/docs
VURIUM_OWNER_EMAIL=nazarii@vurium.local
ADMIN_NOTIFY_EMAIL=nazarii@vurium.local

# Required app secrets for stable local/backend auth
JWT_SECRET=replace-with-strong-jwt-secret
ADMIN_JWT_SECRET=replace-with-strong-admin-jwt-secret
PHONE_ENCRYPTION_KEY=replace-with-phone-encryption-key

# Required to switch AI lanes from fallback mode to real model execution
ANTHROPIC_API_KEY=

# Required to make Owner notification emails actually send
RESEND_API_KEY=

# Required for Gmail auth/send flows
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# Optional Google auth aliases if you use the generic names instead
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional later: Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_INDIVIDUAL=
STRIPE_PRICE_PRO=
STRIPE_PRICE_SALON=
STRIPE_PRICE_CUSTOM=

# Optional later: Telnyx
TELNYX_API_KEY=
TELNYX_FROM=
TELNYX_VERIFY_FROM=
TELNYX_VERIFY_PROFILE_ID=
TELNYX_WEBHOOK_PUBLIC_KEY=

# Optional later: Square
SQUARE_APP_ID=
SQUARE_APP_SECRET=
SQUARE_TOKEN=
SQUARE_DEVICE_ID=
SQUARE_LOCATION_ID=
SQUARE_ENV=production

# Optional later: Apple / push / App Store
APPLE_SHARED_SECRET=
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_KEY_P8=
# APNS_KEY_PATH=/absolute/path/to/AuthKey_XXXX.p8
APNS_BUNDLE_ID=com.vurium.VuriumBook
APNS_ENVIRONMENT=sandbox
